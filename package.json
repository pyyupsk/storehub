{
  "name": "@pyyupsk/storehub",
  "type": "module",
  "version": "0.1.0",
  "description": "Unofficial TypeScript client for the StoreHub POS API",
  "author": "pyyupsk",
  "license": "MIT",
  "homepage": "https://github.com/pyyupsk/storehub#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pyyupsk/storehub.git"
  },
  "bugs": {
    "url": "https://github.com/pyyupsk/storehub/issues"
  },
  "keywords": [
    "storehub",
    "pos",
    "api-client",
    "typescript",
    "retail",
    "inventory",
    "pos-system",
    "store-management",
    "bun",
    "esm",
    "cjs"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --cache",
    "lint:fix": "eslint --fix --cache",
    "lint:docs": "eslint --cache",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "prepare": "lefthook install",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@commitlint/types": "^21.0.0",
    "@eslint/js": "^10.0.1",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.6.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "knip": "^6.12.1",
    "lefthook": "^2.1.6",
    "markdownlint-cli2": "^0.22.1",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "preact": "^10.28.2"
  }
}
